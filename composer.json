{
    "name": "davidcolquhoun/monitor-exceptions-silverstripe",
    "description": "Light weight PHP exception monitoring for SilverStripe.",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Monitor\\Exceptions\\": "src/"
        }
    },
    "authors": [
        {
            "name": "David Colquhoun",
            "email": "davidc@datasmugglers.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "monolog/monolog": "^3.0",
        "silverstripe/framework": "^6.1",
        "symfony/http-foundation": "^7.2.0"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    }
}
